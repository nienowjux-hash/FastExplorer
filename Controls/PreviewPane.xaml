<UserControl
    x:Class="FastExplorer.Controls.PreviewPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="EmptyState" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Select a file to preview" Opacity="0.6" />
        </Grid>

        <Image x:Name="ImagePreview" Visibility="Collapsed" Stretch="Uniform" VerticalAlignment="Top" />

        <ScrollViewer x:Name="TextPreviewScroller" Visibility="Collapsed">
            <TextBlock x:Name="TextPreview" TextWrapping="Wrap" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
        </ScrollViewer>

        <StackPanel x:Name="GenericState" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <FontIcon x:Name="GenericIcon" FontFamily="Segoe Fluent Icons" FontSize="48" Opacity="0.7" />
            <TextBlock x:Name="GenericName" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="220" TextAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="2" Margin="0,12,0,0">
            <TextBlock x:Name="InfoName" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock x:Name="InfoDetails" Opacity="0.6" FontSize="12" />
        </StackPanel>
    </Grid>
</UserControl>
