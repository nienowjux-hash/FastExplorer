<UserControl
    x:Class="FastExplorer.Controls.DuplicatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FastExplorer.Models"
    mc:Ignorable="d">

    <!-- Same 500px-wide, ContentDialog-hosted shape as DiskUsageView/RecycleBinView -
         see those for why (ContentDialog's ~548px content-width cap). The list row is a
         *fixed* pixel height rather than "*" with the outer Grid stretched to fill its
         parent (as RecycleBinView does): a Star row only gets real space if the Grid
         itself is given enough height by its parent, and a shorter FastExplorer window
         left no room for it, silently clipping the SmartSelectButton/DeleteButton row
         and the ConfirmPanel below the list with no scrollbar to reveal them. A fixed
         list height makes the whole Grid autosize to its own content instead, so the
         toolbar row is always visible regardless of window size. -->
    <Grid Width="500" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="260" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button x:Name="RefreshButton" Content="Buscar novamente" Click="RefreshButton_Click" />
            <ProgressRing x:Name="LoadingRing" Width="16" Height="16" IsActive="False" VerticalAlignment="Center" />
            <Button x:Name="CancelScanButton" Content="Cancelar" Click="CancelScanButton_Click"
                    IsEnabled="False" Padding="8,0" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="SummaryText" Grid.Row="1" Opacity="0.7" FontSize="12" />

        <Grid Grid.Row="2">
            <ListView x:Name="ItemsList" SelectionMode="Multiple"
                      SelectionChanged="ItemsList_SelectionChanged">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Nome" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="Grupo / pasta" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="Tamanho" Opacity="0.6" FontSize="12" Width="70" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:DuplicateFileRow">
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock Text="{x:Bind GroupLabel}" Opacity="0.7" FontSize="11" />
                                <TextBlock Text="{x:Bind FolderPath}" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}" Width="70" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="EmptyStateText" Text="Nenhum arquivo duplicado encontrado."
                       Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button x:Name="SmartSelectButton" Content="Selecionar cópias automaticamente" Click="SmartSelectButton_Click" />
            <Button x:Name="DeleteButton" Content="Excluir selecionados" Click="DeleteButton_Click" IsEnabled="False" />
        </StackPanel>

        <!-- Inline confirmation, not a nested ContentDialog - this view is itself hosted
             inside a ContentDialog, and WinUI only allows one open per XamlRoot at a
             time (see CLAUDE.md / RecycleBinView). -->
        <Border x:Name="ConfirmPanel" Grid.Row="4" Visibility="Collapsed"
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ConfirmText" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ConfirmYesButton" Content="Confirmar" Click="ConfirmYesButton_Click" />
                    <Button x:Name="ConfirmNoButton" Content="Cancelar" Click="ConfirmNoButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
