<UserControl
    x:Class="FastExplorer.Controls.PropertiesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FastExplorer.Models"
    mc:Ignorable="d">

    <ScrollViewer MaxHeight="480">
        <StackPanel Spacing="12" Width="420">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="HeaderIcon" FontFamily="Segoe Fluent Icons" FontSize="32" />
                <TextBlock x:Name="HeaderName" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Grid ColumnSpacing="12" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" Opacity="0.6" />
                <TextBlock x:Name="TypeText" Grid.Row="0" Grid.Column="1" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" Opacity="0.6" />
                <TextBlock x:Name="LocationText" Grid.Row="1" Grid.Column="1" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" Opacity="0.6" />
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="SizeText" TextTrimming="CharacterEllipsis" />
                    <ProgressRing x:Name="SizeSpinner" Width="14" Height="14" IsActive="False" />
                    <HyperlinkButton x:Name="CancelSizeButton" Content="Cancel" Click="CancelSizeButton_Click" Visibility="Collapsed" Padding="0" />
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Created" Opacity="0.6" />
                <TextBlock x:Name="CreatedText" Grid.Row="3" Grid.Column="1" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Modified" Opacity="0.6" />
                <TextBlock x:Name="ModifiedText" Grid.Row="4" Grid.Column="1" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Accessed" Opacity="0.6" />
                <TextBlock x:Name="AccessedText" Grid.Row="5" Grid.Column="1" />
            </Grid>

            <StackPanel x:Name="AttributesPanel" Orientation="Horizontal" Spacing="16">
                <CheckBox x:Name="ReadOnlyCheck" Content="Read-only" />
                <CheckBox x:Name="HiddenCheck" Content="Hidden" />
            </StackPanel>

            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <TextBlock Text="Security" FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Owner" Opacity="0.6" Width="90" />
                <TextBlock x:Name="OwnerText" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <ListView x:Name="AccessRulesList" MaxHeight="160" SelectionMode="None">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Account" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="Type" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="Permissions" Opacity="0.6" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AccessRuleInfo">
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Identity}" FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{x:Bind AccessType}" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="{x:Bind Rights}" FontSize="12" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</UserControl>
