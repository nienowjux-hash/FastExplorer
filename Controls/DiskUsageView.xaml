<UserControl
    x:Class="FastExplorer.Controls.DiskUsageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Fixed 500px width to stay comfortably under ContentDialog's own ~548px
         content-width cap (see CLAUDE.md / RecycleBinView, which hit this the hard
         way) - CanvasWidth/CanvasHeight in code-behind must match TreemapCanvas's
         declared size below exactly, since TreemapLayout.Compute needs real pixel
         bounds up front and reading ActualWidth/Height would race the first layout pass. -->
    <Grid Width="500" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button x:Name="BackButton" Content="Voltar" Click="BackButton_Click" IsEnabled="False" />
            <Button x:Name="RefreshButton" Content="Atualizar" Click="RefreshButton_Click" />
            <ProgressRing x:Name="LoadingRing" Width="16" Height="16" IsActive="False" VerticalAlignment="Center" />
            <Button x:Name="CancelScanButton" Content="Cancelar" Click="CancelScanButton_Click"
                    IsEnabled="False" Padding="8,0" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="PathText" Grid.Row="1" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis" />

        <Border Grid.Row="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Canvas x:Name="TreemapCanvas" Width="480" Height="340" Background="Transparent" />
                <TextBlock x:Name="EmptyStateText" Text="Pasta vazia." Opacity="0.6"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="SelectionText" Opacity="0.8" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <Button x:Name="DeleteButton" Content="Excluir" Click="DeleteButton_Click" IsEnabled="False" Padding="8,0" FontSize="12" />
        </StackPanel>

        <!-- Inline confirmation, not a nested ContentDialog - this view is itself
             hosted inside a ContentDialog (FolderView's "Analisar espaço em disco"),
             and WinUI only allows one ContentDialog open per XamlRoot at a time (see
             CLAUDE.md / RecycleBinView, which crashed the whole app the first time
             this was gotten wrong). -->
        <Border x:Name="ConfirmPanel" Grid.Row="4" Visibility="Collapsed"
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ConfirmText" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ConfirmYesButton" Content="Confirmar" Click="ConfirmYesButton_Click" />
                    <Button x:Name="ConfirmNoButton" Content="Cancelar" Click="ConfirmNoButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
