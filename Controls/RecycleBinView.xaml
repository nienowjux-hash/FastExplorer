<UserControl
    x:Class="FastExplorer.Controls.RecycleBinView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FastExplorer.Models"
    mc:Ignorable="d">

    <!-- ContentDialog's default template caps content width around ~548px (the
         ContentDialogMaxWidth theme resource) regardless of what this UserControl asks
         for, and the four toolbar buttons don't fit in one row within that budget -
         wrapping them into two rows (rather than widening the dialog, which would fight
         that cap) is what keeps everything on-screen at any window size. The list row is
         a *fixed* pixel height, not "*" - a Star row only gets real space once the outer
         Grid actually receives that much height from its parent, and on a short
         FastExplorer window it doesn't, silently clipping StatusText/ConfirmPanel below
         the list with no scrollbar to reveal them (found while fixing the identical bug
         in DuplicatesView - see its comment for the full explanation). A fixed height
         makes the whole Grid autosize to its own content instead. -->
    <Grid Width="500" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="260" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RestoreButton" Content="Restaurar selecionados" Click="RestoreButton_Click" IsEnabled="False" />
                <Button x:Name="DeleteButton" Content="Excluir permanentemente" Click="DeleteButton_Click" IsEnabled="False" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="EmptyButton" Content="Esvaziar lixeira" Click="EmptyButton_Click" />
                <Button x:Name="RefreshButton" Content="Atualizar" Click="RefreshButton_Click" />
                <ProgressRing x:Name="LoadingRing" Width="16" Height="16" IsActive="False" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <ListView x:Name="ItemsList" SelectionMode="Multiple"
                      SelectionChanged="ItemsList_SelectionChanged">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Nome" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="Local original" Opacity="0.6" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="Excluído em" Opacity="0.6" FontSize="12" Width="130" />
                            <TextBlock Grid.Column="3" Text="Tamanho" Opacity="0.6" FontSize="12" Width="70" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:RecycleBinItemInfo">
                        <Grid Padding="4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{x:Bind DeletedFrom}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{x:Bind DateDeletedDisplay}" Width="130" />
                            <TextBlock Grid.Column="3" Text="{x:Bind SizeDisplay}" Width="70" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="EmptyStateText" Text="A lixeira está vazia."
                       Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Inline confirmation, not a nested ContentDialog: this view is itself hosted
             inside MainWindow's ContentDialog (RecycleBinButton_Click), and WinUI only
             allows one ContentDialog open per XamlRoot at a time - a second ShowAsync
             here throws (app has no UnhandledException handler, so that crashes the
             whole process, not just this dialog), which is exactly what a nested
             ContentDialog attempt for this did before this panel replaced it. -->
        <Border x:Name="ConfirmPanel" Grid.Row="2" Visibility="Collapsed"
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ConfirmText" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ConfirmYesButton" Content="Confirmar" Click="ConfirmYesButton_Click" />
                    <Button x:Name="ConfirmNoButton" Content="Cancelar" Click="ConfirmNoButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="3" Opacity="0.6" FontSize="12" />
    </Grid>
</UserControl>
