<UserControl
    x:Class="FastExplorer.Controls.ImageBatchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Width="420" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock x:Name="CountText" Opacity="0.7" FontSize="12" />
            <TextBlock x:Name="SourceSizeText" Opacity="0.6" FontSize="12" Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Formato de saída" FontSize="12" Opacity="0.7" />
            <ComboBox x:Name="FormatCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Manter formato original" Tag="Keep" />
                <ComboBoxItem Content="Converter para JPG" Tag="Jpeg" />
                <ComboBoxItem Content="Converter para PNG" Tag="Png" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Redimensionar (maior dimensão)" FontSize="12" Opacity="0.7" />
            <ComboBox x:Name="SizePresetCombo" SelectedIndex="0" HorizontalAlignment="Stretch"
                      SelectionChanged="SizePresetCombo_SelectionChanged">
                <ComboBoxItem Content="Manter tamanho original" Tag="" />
                <ComboBoxItem Content="Grande (1920 px)" Tag="1920" />
                <ComboBoxItem Content="Média (1280 px)" Tag="1280" />
                <ComboBoxItem Content="Pequena (800 px)" Tag="800" />
                <ComboBoxItem Content="Miniatura (320 px)" Tag="320" />
                <ComboBoxItem Content="Personalizado..." Tag="custom" />
            </ComboBox>
            <NumberBox x:Name="MaxDimensionBox" PlaceholderText="Valor em pixels"
                       SpinButtonPlacementMode="Compact" Minimum="1" HorizontalAlignment="Stretch"
                       Visibility="Collapsed" />
            <CheckBox x:Name="AllowUpscaleCheck" Content="Forçar esse tamanho mesmo se a imagem for menor (pode perder qualidade)"
                      Visibility="Collapsed" />
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="DestinationText" Opacity="0.6" FontSize="12" TextWrapping="Wrap" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
            <Button x:Name="RunButton" Content="Converter" Click="RunButton_Click" />
            <ProgressRing x:Name="LoadingRing" Width="16" Height="16" IsActive="False" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusText" Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
