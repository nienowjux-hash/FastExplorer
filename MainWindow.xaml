<Window
    x:Class="FastExplorer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:FastExplorer.Controls"
    xmlns:services="using:FastExplorer.Services"
    xmlns:models="using:FastExplorer.Models"
    xmlns:converters="using:FastExplorer.Converters"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:AccentColorToBrushConverter x:Key="AccentColorToBrushConverter" />
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        </Grid.Resources>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="NewTabAccelerator_Invoked" />
            <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="CloseTabAccelerator_Invoked" />
            <KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="NextTabAccelerator_Invoked" />
            <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="PreviousTabAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="FastExplorer" FontWeight="SemiBold" FontSize="16" Padding="16,16,16,8"
                       Foreground="{Binding AccentBrush}" />

            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="8,0,8,8" Spacing="4">
                    <TextBlock Text="Favoritos" Opacity="0.6" FontSize="12" Padding="8,8,8,4" />
                    <ListView x:Name="FavoritesList" ItemsSource="{Binding Favorites}"
                              SelectionMode="None" ItemClick="FavoritesList_ItemClick" IsItemClickEnabled="True">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:FavoriteEntry">
                                <Grid Padding="4,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;" FontSize="14"
                                              Foreground="{Binding ElementName=RootGrid, Path=DataContext.AccentBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Text="Este Computador" Opacity="0.6" FontSize="12" Padding="8,12,8,4" />
                    <Button Content="Unidades e dispositivos" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Click="ThisPcButton_Click" />
                    <Button Content="Mapear unidade de rede..." HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Click="MapNetworkDriveButton_Click" />

                    <TextBlock Text="Tema" Opacity="0.6" FontSize="12" Padding="8,12,8,4" />
                    <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" Margin="8,0,8,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Cor de destaque" Opacity="0.6" FontSize="12" Padding="8,12,8,4" />
                    <ComboBox ItemsSource="{Binding AvailableAccentColors}" SelectedItem="{Binding SelectedAccentColor, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" Margin="8,0,8,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="14" Height="14" Fill="{Binding Converter={StaticResource AccentColorToBrushConverter}}" />
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="Mostrar arquivos ocultos" IsChecked="{Binding ShowHiddenFiles, Mode=TwoWay}"
                              Margin="8,12,8,0" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Split-pane tree: a leaf renders as a tab strip (PaneGroupView), a split
             renders as two of these side by side / stacked (SplitContainerView),
             recursively - see the PaneNodeTemplateSelector in App.xaml. -->
        <ContentControl Grid.Column="1" Content="{Binding RootPane}"
                        ContentTemplateSelector="{StaticResource PaneNodeTemplateSelector}"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />

        <!-- Preview pane -->
        <Grid Grid.Column="2" BorderThickness="1,0,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <controls:PreviewPane x:Name="PreviewPaneControl" />
        </Grid>
    </Grid>
</Window>
